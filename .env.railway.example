# Copier ces variables dans Railway → Service → Variables → Raw Editor
# Remplacer les valeurs entre <...> et les références ${{...}} par vos services Railway.

APP_NAME=NexusSam
APP_ENV=production
APP_KEY=<générer avec: php artisan key:generate --show>
APP_DEBUG=false
APP_URL=https://<votre-domaine>.up.railway.app
APP_TIMEZONE=Europe/Paris

APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr

# Logs visibles dans le dashboard Railway
LOG_CHANNEL=stderr
LOG_LEVEL=info

# --- Base de données (PostgreSQL recommandé sur Railway) ---
DB_CONNECTION=pgsql
DB_URL=${{Postgres.DATABASE_URL}}

# Alternative MySQL (si vous ajoutez un service MySQL au lieu de Postgres) :
# DB_CONNECTION=mysql
# DB_HOST=${{MySQL.MYSQLHOST}}
# DB_PORT=${{MySQL.MYSQLPORT}}
# DB_DATABASE=${{MySQL.MYSQLDATABASE}}
# DB_USERNAME=${{MySQL.MYSQLUSER}}
# DB_PASSWORD=${{MySQL.MYSQLPASSWORD}}

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

CACHE_STORE=database
QUEUE_CONNECTION=sync
FILESYSTEM_DISK=public

BCRYPT_ROUNDS=12

MAIL_MAILER=log
